<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DIExample.Views.ScorePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:DIExample.Models"
    xmlns:viewmodels="clr-namespace:DIExample.ViewModels"
    Title="ScorePage"
    x:DataType="viewmodels:ScorePageViewModel"
    FlowDirection="RightToLeft">
    <VerticalStackLayout
        Padding="30"
        HorizontalOptions="Center"
        Spacing="20"
        VerticalOptions="Center">
        <Label
            FontAttributes="Bold"
            FontSize="30"
            HorizontalOptions="Center"
            Text="המובילים שלנו:" />

        <Label
            FontSize="24"
            HorizontalOptions="Center"
            Text="{Binding ScoresDisplayText}" />
    </VerticalStackLayout>
</ContentPage>